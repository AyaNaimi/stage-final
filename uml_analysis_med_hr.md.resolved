## 2. Diagramme de Classes (Spécifique au Module SST)
Ce diagramme de classes est **100% focalisé sur le moteur médical**. Il montre les modèles du code existant, leurs fonctions extraites d'Eloquent ORM et des relations UML strictes (Composition, Agrégation).

// [MermaidChart: 4f743592-3293-4975-958c-740b5897f867]

```mermaid
classDiagram
    class Model {
        <<Framework Eloquent Base>>
        +save()
        +update()
        +delete()
    }

    class Employe {
        +int id
        +String matricule
        +String num_badge
        +String nom
        +String prenom
        +Date date_naiss
        +String sexe
        +String cin
        +String adresse
        +String email
        +String tel
        +float salaire_base
        +visites()
        +medicalRecord()
        +medicalExams()
        +medicalRestrictions()
        +medicalDocuments()
    }
    
    class DossierMedical {
        +int id
        +String numero_dossier
        +String groupe_sanguin
        +String antecedents_personnels
        +String antecedents_familiaux
        +String allergies
        +String vaccinations
        +String notes
        +employe()
    }
    
    class Visite {
        +int id
        +Date date
        +String time
        +String type
        +String statut
        +String emplacement
        +String lieu
        +String medecin_nom
        +String doctor
        +String notes
        +float unit_cost
        +float total_cost
        +String payment_status
        +practitioner()
        +employes()
        +payments()
        +medicalExams()
    }
    
    class ExamenMedical {
        +int id
        +Date date_examen
        +String motif
        +float poids
        +float taille
        +float imc
        +String ta_systolique
        +String ta_diastolique
        +String pouls
        +String temperature
        +String glycemie
        +String spo2
        +String aptitude
        +String evaluation
        +String plan
        +Date date_prochaine_visite
        +String doctor_name
        +visite()
        +employe()
        +restrictions()
        +documents()
    }
    
    class MedicalRestriction {
        +int id
        +String description
        +Date date_debut
        +Date date_fin
        +boolean est_permanent
        +String statut
        +employe()
        +examenMedical()
    }
    
    class MedicalDocument {
        +int id
        +String nom
        +String type
        +String chemin_fichier
        +Date date_document
        +employe()
        +examenMedical()
    }

    class SSTPractitioner {
        +int id
        +String name
        +String first_name
        +String specialty
        +String type
        +String phone
        +String email
        +String photo
        +String diplome
        +String contract_type
        +float remuneration_amount
        +String status
        +visits()
        +payments()
    }
    
    class SSTPayment {
        +int id
        +float amount
        +String reference
        +String status
        +Date payment_date
        +String notes
        +practitioner()
        +visits()
    }

    Model <|-- Employe : Héritage
    Model <|-- DossierMedical : Héritage
    Model <|-- Visite : Héritage
    Model <|-- ExamenMedical : Héritage
    Model <|-- MedicalRestriction : Héritage
    Model <|-- MedicalDocument : Héritage
    Model <|-- SSTPractitioner : Héritage
    Model <|-- SSTPayment : Héritage

    %% Relations
    Employe "1" *-- "1" DossierMedical : Composition
    Employe "*" -- "*" Visite : Association (pivot employe_visite)
    Employe "1" *-- "*" ExamenMedical : Composition
    Employe "1" *-- "*" MedicalRestriction : Composition
    Employe "1" *-- "*" MedicalDocument : Composition
    
    Visite "1" *-- "*" ExamenMedical : Composition
    ExamenMedical "1" *-- "*" MedicalRestriction : Composition
    ExamenMedical "1" *-- "*" MedicalDocument : Composition
    
    SSTPractitioner "1" o-- "*" Visite : Agrégation
    SSTPractitioner "1" o-- "*" SSTPayment : Agrégation
    Visite "*" -- "*" SSTPayment : Association (pivot sst_payment_visit)

    %% Styling 
    style Employe fill:#4CAF50,stroke:#2E7D32,stroke-width:2px,color:#fff
    style DossierMedical fill:#E91E63,stroke:#AD1457,stroke-width:2px,color:#fff
    style Visite fill:#F06292,stroke:#C2185B,stroke-width:2px,color:#fff
    style ExamenMedical fill:#FFC107,stroke:#FF8F00,stroke-width:2px,color:#000
    style MedicalRestriction fill:#FF9800,stroke:#E65100,stroke-width:2px,color:#000
    style MedicalDocument fill:#9C27B0,stroke:#6A1B9A,stroke-width:2px,color:#fff

## 7. Modèle Logique de Données (MLD) - Base de Données SST
Ce diagramme entité-association (ERD) traduit les Modèles Applicatifs vus précédemment en **Tables Physiques et Clés Étrangères (Foreign Keys)** telles qu'elles sont stockées dans la base de données relationnelle.

```mermaid
erDiagram
    %% Tables Principales
    employes {
        int id PK
        string matricule
        string num_badge
        string nom
        string prenom
        date date_naiss
        string sexe
        string cin
        string adresse
        string email
        string tel
        float salaire_base
    }

    sst_practitioners {
        int id PK
        string name
        string first_name
        string specialty
        string type
        string phone
        string email
        string status
        string contract_type
        float remuneration_amount
    }

    %% Tables Métier SST
    dossier_medicals {
        int id PK
        int employe_id FK
        string numero_dossier
        string groupe_sanguin
        text antecedents_personnels
        text antecedents_familiaux
        string allergies
        string vaccinations
        text notes
    }

    visites {
        int id PK
        int practitioner_id FK
        date date
        string time
        string type
        string statut
        string emplacement
        string lieu
        string doctor
        text notes
        decimal unit_cost
        decimal total_cost
        string payment_status
    }

    examen_medicals {
        int id PK
        int visite_id FK
        int employe_id FK
        date date_examen
        string motif
        float poids
        float taille
        float imc
        string ta_systolique
        string ta_diastolique
        string pouls
        string temperature
        string glycemie
        string aptitude
        string evaluation
        string doctor_name
    }

    medical_restrictions {
        int id PK
        int employe_id FK
        int examen_medical_id FK
        text description
        date date_debut
        date date_fin
        boolean est_permanent
        string statut
    }

    medical_documents {
        int id PK
        int employe_id FK
        int examen_medical_id FK
        string nom
        string type
        string chemin_fichier
        date date_document
    }

    sst_payments {
        int id PK
        int practitioner_id FK
        decimal amount
        string reference
        string status
        date payment_date
        text notes
    }

    %% Tables de Pivot (Many-to-Many)
    employe_visite {
        int employe_id FK
        int visite_id FK
        string statut_individuel
    }

    sst_payment_visit {
        int sst_payment_id FK
        int visite_id FK
    }

    %% Relations Base de Données (Foreign Keys)
    employes ||--o| dossier_medicals : "possède 1"
    
    %% Examen -> Visite et Employe
    visites ||--o{ examen_medicals : "contient"
    employes ||--o{ examen_medicals : "passe"
    
    %% Restrictions et Documents
    employes ||--o{ medical_restrictions : "subit"
    examen_medicals ||--o{ medical_restrictions : "déclenche"
    
    employes ||--o{ medical_documents : "possède"
    examen_medicals ||--o{ medical_documents : "justifie"

    %% Praticiens et Facturation
    sst_practitioners ||--o{ visites : "supervise"
    sst_practitioners ||--o{ sst_payments : "reçoit"
    
    %% Relations Pivot (M:M) -> Converties en 1:M vers la table pivot
    employes ||--o{ employe_visite : "appartient à (pivot)"
    visites ||--o{ employe_visite : "inclut (pivot)"
    
    sst_payments ||--o{ sst_payment_visit : "inclut (pivot)"
    visites ||--o{ sst_payment_visit : "justifie (pivot)"
```
